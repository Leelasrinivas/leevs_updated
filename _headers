# LEEVS.IN — Cloudflare Pages Headers Configuration
# Optimizes Caching, Security Headers, and Google Core Web Vitals Performance

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: no-referrer-when-downgrade
  Permissions-Policy: interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache-Control settings for static assets (CSS, JS)
/style.css
  Cache-Control: public, max-age=31536000, immutable

/script.js
  Cache-Control: public, max-age=31536000, immutable

# Cache-Control settings for icons/favicons
/*.ico
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.svg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Cache-Control for manifest.json
/manifest.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600
